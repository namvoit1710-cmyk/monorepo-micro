{
  "name": "@ldc/tailwind-config",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./core": "./styles/core.css",
    "./theme": "./styles/theme.css",
    "./themes/*": "./themes/*.css",
    "./styles/*": "./styles/*.css"
  },
  "license": "MIT",
  "scripts": {
    "generate-theme": "bun run scripts/generate-theme.ts",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/postcss": "catalog:",
    "postcss": "^8.5.6",
    "tailwindcss": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ldc/eslint-config": "workspace:*",
    "@ldc/prettier-config": "workspace:*",
    "@ldc/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@ldc/prettier-config"
}
